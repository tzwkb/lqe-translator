    {"id": "en-hehe", "pattern": "\\bHehe\\b", "where": "target", "category": "Company style", "severity": "Minor", "comment": "更新要求6/8: 禁Hehe→Heh/(Playful Laugh)/(Giggle)/省略"},
    {"id": "en-little-roco", "pattern": "\\bLittle Roco\\b", "where": "target", "category": "Company style", "severity": "Major", "comment": "更新要求5/28: 小洛克禁Little Roco→Young Roco/kid"},
    {"id": "en-banned-title", "pattern": "Roco Kingdom: World", "where": "target", "category": "Terminology", "severity": "Critical", "comment": "违禁词: 游戏名=Roco Kingdom，'世界'不译"},
    {"id": "en-dual-stats", "pattern": "Physical and Magic (Attack|Defense)", "where": "target", "category": "Terminology", "severity": "Major", "comment": "更新要求6/8: 双攻/双防=Dual Attack/Dual Defense"},
