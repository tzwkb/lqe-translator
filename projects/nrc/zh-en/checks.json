    {"id": "en-slang", "pattern": "(?i)\\bno cap\\b|\\bsus\\b", "where": "target", "category": "Company style", "severity": "Minor", "comment": "EN-SG: 禁网络俚语(bro/sus/no cap)"},
    {"id": "en-jini-plural", "pattern": "\\bJinis\\b", "where": "target", "category": "Terminology", "severity": "Minor", "comment": "changelog: Jini复数=Jinies"}
