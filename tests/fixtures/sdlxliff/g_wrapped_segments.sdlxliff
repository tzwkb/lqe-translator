        <target><g id="outer"><g id="inner"><mrk mtype="seg" mid="1" v:segment-meta="target-one">Alpha<x id="x1"/>tail</mrk><mrk mtype="seg" mid="2" v:segment-meta="target-two">Beta</mrk></g></g></target>
